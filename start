import telebot
from PyPDF2 import PdfReader


bot = telebot.TeleBot("7756223312:AAFRPLTx19Sh5QmFREYl3qfTm_LJu8Ceinw")

pdf_content = {}


@bot.message_handler(content_types=['document'])
def handle_document(message):
    file_info = bot.get_file(message.document.file_id)
    downloaded_file = bot.download_file(file_info.file_path)

    with open('uploaded_file.pdf', 'wb') as new_file:
        new_file.write(downloaded_file)

    reader = PdfReader('uploaded_file.pdf')
    content = ""
    for page in reader.pages:
        content += page.extract_text() + '\n'

    pdf_content[message.chat.id] = content
    bot.reply_to(message,
                 "PDF файл был успешно загружен и обработан.\nВы можете получить данные, используя команды /get или /all.")


@bot.message_handler(commands=['get'])
def get_data(message):
    if message.chat.id in pdf_content:
        bot.send_message(message.chat.id,
                         "Введите ключевое слово или фразу, чтобы получить соответствующую информацию из PDF:")
        bot.register_next_step_handler(message, send_relevant_data)
    else:
        bot.reply_to(message, "Сначала загрузите PDF файл.")


def send_relevant_data(message):
    keyword = message.text
    content = pdf_content[message.chat.id]

    relevant_lines = [line for line in content.split('\n') if keyword.lower() in line.lower()]

    if relevant_lines:
        response = "Вот информация, которую я нашел:\n\n" + "\n".join(relevant_lines)
    else:
        response = "К сожалению, я не нашел информации по вашему запросу."

    bot.send_message(message.chat.id, response)


@bot.message_handler(commands=['all'])
def send_all_data(message):
    if message.chat.id in pdf_content:
        content = pdf_content[message.chat.id]
        response = "Вот все данные из вашего PDF файла:\n" + content
        bot.send_message(message.chat.id, response)
    else:
        bot.reply_to(message, "Сначала загрузите PDF файл.")


bot.polling()
