import telebot
from PyPDF2 import PdfReader
import gspread
from oauth2client.service_account import ServiceAccountCredentials
import re

API_TOKEN = "7756223312:AAFRPLTx19Sh5QmFREYl3qfTm_LJu8Ceinw"
bot = telebot.TeleBot(API_TOKEN)

# Настройка доступа к Google Sheets
scope = ["https://spreadsheets.google.com/feeds", "https://www.googleapis.com/auth/drive"]
creds = ServiceAccountCredentials.from_json_keyfile_name('D:/tgg/transfertablesbot-56526b15c394.json', scope)
client = gspread.authorize(creds)

# Открытие Google Таблицы
spreadsheet = client.open("PDF Data").sheet1

# Хранение загруженного файла
pdf_content = {}


# Функция для извлечения Плательщика
def extract_payer(text):
    payer_pattern = r"Плательщик\s*(?:ООО|ИП|ПАО|АО)\s[\"«]?[А-Яа-яЁё0-9\s\-—]+[\"»]?"
    payer = re.findall(payer_pattern, text)
    if payer:
        return payer[0].replace("Плательщик", "").strip()

    org_pattern = r"(?:ООО|ИП|ПАО|АО)\s[\"«]?[А-Яа-яЁё0-9\s\-—]+[\"»]?"
    organizations = re.findall(org_pattern, text)
    return organizations[0] if organizations else ""

# Функция для извлечения Получателя
def extract_recipient(text):
    recipient_pattern = r"Получатель\s*(?:ООО|ИП|ПАО|АО|)\s[\"«]?[А-Яа-яЁё0-9\s\-—]+[\"»]?"
    recipient = re.findall(recipient_pattern, text)
    if recipient:
        return recipient[0].replace("Получатель", "").strip()

    org_pattern = r"(?:ООО|ИП|ПАО|АО|)\s[\"«]?[А-Яа-яЁё0-9\s\-—]+[\"»]?"
    organizations = re.findall(org_pattern, text)
    return organizations[3] if len(organizations) > 3 else ""

# Функция для извлечения Даты
def extract_dates(text):
    date_pattern = r"\d{2}\.\d{2}\.\d{4}"
    dates = re.findall(date_pattern, text)
    return dates[2] if len(dates) > 2 else ""

# Функция для извлечения ИНН
def extract_inn(text):
    inn_pattern = r"\b\d{10}\b"
    inns = re.findall(inn_pattern, text)
    return inns

# Функция для извлечения Суммы
def extract_amounts(text):
    amount_pattern = r"\d+-\d{2}"
    amounts = re.findall(amount_pattern, text)
    return amounts[0] if amounts else ""

# Функция для извлечения Статуса платежа
def extract_payment_status(text):
    status_pattern = r"ПРОВЕДЕНО|Исполнен"
    match = re.search(status_pattern, text)
    return match.group() if match else ""


# Функция для проверки и добавления заголовков
def ensure_headers():
    existing_headers = spreadsheet.row_values(1)
    required_headers = ["Плательщик", "Получатель", "Дата", "ИНН плательщика", "ИНН получателя", "Сумма",
                        "Статус платежа"] # Заголовки

    if existing_headers != required_headers:
        spreadsheet.insert_row(required_headers, 1) # Если заголовки отсутствуют


@bot.message_handler(content_types=['document'])
def handle_document(message):
    try:
        file_info = bot.get_file(message.document.file_id)
        downloaded_file = bot.download_file(file_info.file_path)

        # Сохранение файла
        with open('uploaded_file.pdf', 'wb') as new_file:
            new_file.write(downloaded_file)

        # Чтение содержимого PDF
        reader = PdfReader('uploaded_file.pdf')
        content = ""
        for page in reader.pages:
            content += page.extract_text() + '\n'

        # Сохраняем содержимое PDF для текущего чата
        pdf_content[message.chat.id] = content

        # Извлечение данных
        payer = extract_payer(content)  # Извлекаем Плательщика
        recipient = extract_recipient(content)  # Извлекаем Получателя
        date = extract_dates(content)  # Извлекаем Дату
        amount = extract_amounts(content)  # Извлекаем Сумму
        inns = extract_inn(content)  # Извлекаем ИНН
        payer_inn = inns[0] if len(inns) > 0 else "" # ИНН плательщика
        recipient_inn = inns[1] if len(inns) > 1 else "" # ИНН получателя
        payment_status = extract_payment_status(content)  # Извлекаем статус платежа


        # Убедимся, что заголовки есть в таблице
        ensure_headers()

        # Подготовка данных для Google Таблицы
        data_to_insert = []

        # Добавление данных в Google Таблицу
        data_to_insert.append([payer, recipient, date, payer_inn, recipient_inn, amount, payment_status])

        # Логирование данных перед добавлением
        print("Данные для добавления:", data_to_insert)

        # Добавление новых данных в Google Таблицу (без очистки старых данных)
        spreadsheet.append_rows(data_to_insert)

        bot.reply_to(message, "PDF файл был успешно добавлен в Google Таблицу.")
    except Exception as e:
        print("Ошибка:", e)
        bot.reply_to(message, f"Произошла ошибка при обработке файла: {e}")


# Команда /all
@bot.message_handler(commands=['all'])
def show_pdf_content(message):
    # Проверяем, есть ли сохраненное содержимое PDF для этого чата
    if message.chat.id in pdf_content:
        content = pdf_content[message.chat.id]
        # Отправляем содержимое PDF в чат
        # Если текст слишком длинный, разбиваем его на части
        if len(content) > 4096:
            for part in [content[i:i + 4096] for i in range(0, len(content), 4096)]:
                bot.send_message(message.chat.id, part)
        else:
            bot.send_message(message.chat.id, content)
    else:
        bot.send_message(message.chat.id, "Нет загруженного PDF-файла для этого чата.")

bot.polling()
